# Live Base Sepolia deployment — clone-and-run works out of the box.
# Deploy your own with `forge script script/Deploy.s.sol:Deploy --broadcast` and paste the new address here.
VITE_TIPJAR_ADDRESS=0x2b7aD12C066181c354a615A3c6ce1edAf4c6Ef33

# Optional: replace with an Alchemy / QuickNode endpoint if the public RPC rate-limits you.
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: required only for WalletConnect QR pairing (mobile wallets).
# Get one free at https://cloud.reown.com — without this, injected wallets (MetaMask, Coinbase, Rabby) still work.
VITE_WC_PROJECT_ID=
